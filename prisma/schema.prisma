generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "mysql"   
}


model ChangeLog {
  id         BigInt   @id @default(autoincrement())
  userId     String
  tableName  String
  recordId   String
  operation  String   // create | update | delete
  createdAt  DateTime @default(now())

  @@index([userId, id])
}



model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String    
  username    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

   
}


model TestItem {
  id        String   @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

