model ChangeLog {
  id        BigInt   @id @default(autoincrement())
  userId    String
  entity    String   // tableName (es. "testItem")
  recordId  String
  operation String   // "create" | "update" | "delete"
  payload   Json?    // <--- Contiene i dati dell'oggetto (es. { title: "..." })
  deviceId  String   // Per evitare che il mittente ri-applichi la sua stessa modifica
  createdAt DateTime @default(now())

  @@index([userId, id])
}



model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String    
  username    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

   
}


model TestItem {
  id        String   @id @default(uuid())
  title     String

  userId    String  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}


model Categoria {
  idCategoria String    @id @default(uuid()) 
  categoria   String      
  image       String?    @default("")

  userId    String

  createdAt              DateTime   @default(now())  
  updatedAt              DateTime   @default(now()) @updatedAt

  //ricette     Ricette[]
  @@unique([categoria, userId])  //unicità categoria - utente
  @@unique([idCategoria, userId])
  @@map("categoria")
}

model Area {  
  idArea   String    @id @default(uuid()) 
  area     String    
  image    String?    @default("")

  userId    String

  createdAt              DateTime   @default(now()) //aggiunti dopo
  updatedAt              DateTime   @default(now()) @updatedAt

  //ricette Ricette[] 

  @@unique([area, userId]) // Garantisce che un utente non abbia due aree con lo stesso nome
  @@unique([idArea, userId]) //come un index per le ricerche
  @@map("area")
}

model Tag {
  idTag   String    @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  tag     String     
  color   String    @default("bg-lime-100")

  userId    String

  //ricette RicettaTag[]   rimosso temporaneamente

  createdAt              DateTime   @default(now())  
  updatedAt              DateTime   @default(now()) @updatedAt

  @@unique([tag, userId])  
  @@unique([idTag, userId])
  @@map("tag")
}

