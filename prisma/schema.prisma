model ChangeLog {
  id        BigInt   @id @default(autoincrement())
  userId    String
  entity    String   // tableName (es. "testItem")
  recordId  String
  operation String   // "create" | "update" | "delete"
  payload   Json?    // <--- Contiene i dati dell'oggetto (es. { title: "..." })
  deviceId  String   // Per evitare che il mittente ri-applichi la sua stessa modifica
  createdAt DateTime @default(now())

  @@index([userId, id])
}



model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String    
  username    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

   
}


model TestItem {
  id        String   @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

